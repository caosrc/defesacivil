modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_database:1.0.0", "replitmail:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["netlify-cli"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install --silent && PORT=3001 node server/index.js & node_modules/.bin/vite --host 0.0.0.0 --port 5000"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server/index.js"]
build = ["npx", "vite", "build"]

[userenv]

[userenv.shared]
VITE_USE_SUPABASE = "false"
NODE_ENV = "production"
VAPID_SUBJECT = "mailto:defesacivilob@gmail.com"
VAPID_PUBLIC_KEY = "BM-gE-wibZiGkyOPTZVRfjL0cVY7pzBfDTIAHaSTZDOoiq03OiTaUYN8RfKHCfpyrkoML2EukgmbqwrT6HxBkBk"

[userenv.development]
PORT = "3001"

[userenv.production]
PORT = "5000"
