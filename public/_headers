# Defesa Civil Ouro Branco — cabeçalhos para Netlify

# Service Worker NUNCA pode ser cacheado, senão atualizações nunca chegam
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

# Manifest também precisa atualizar rápido
/manifest.json
  Cache-Control: public, max-age=0, must-revalidate

# Assets com hash do Vite podem ser cacheados por muito tempo
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Ícones e logos do PWA podem ser cacheados moderadamente
/icon-192.png
  Cache-Control: public, max-age=86400
/icon-512.png
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400
