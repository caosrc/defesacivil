# ─── Configuração para deploy do FRONTEND no Netlify ──────────────────────────
# Netlify só serve arquivos estáticos. O backend Express + WebSocket precisa
# rodar em outro lugar (ex.: Replit Deployments). Sem essas variáveis o
# rastreamento GPS em tempo real e os alertas SOS NÃO funcionam em produção.

# URL pública do backend (o Deployment do Replit, por exemplo).
# NÃO coloque barra no fim. Não inclua /api — o app já adiciona.
VITE_API_URL=https://defesacivilob.SEU-USUARIO.replit.app

# Opcional: URL do WebSocket. Se não definir, é derivada do VITE_API_URL
# automaticamente (https → wss). Só precisa preencher se o WS rodar em
# outro host diferente do backend HTTP.
# VITE_WS_URL=wss://defesacivilob.SEU-USUARIO.replit.app

# ─── Backend (server/index.js) ────────────────────────────────────────────────
# DATABASE_URL é injetado automaticamente pelo Replit ao provisionar o Postgres.
# DATABASE_URL=postgresql://...
