# ─── Configuração do Supabase (necessário em DEV e em PROD) ───────────────────
# O app usa Supabase Realtime para SOS e GPS em tempo real entre agentes.
# Sem essas variáveis, o app abre mas nada chega aos outros aparelhos.
#
# No Netlify: Site settings → Environment variables → adicionar as duas variáveis.
# No Replit: já configurado via aba Secrets.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...sua-chave-anon-aqui

# ─── (Opcional) Backend HTTP próprio ──────────────────────────────────────────
# Só usado se você quiser hospedar o servidor Express em outro lugar.
# Em branco = usa caminho relativo (proxy do Vite em dev, mesma origem em prod).
# VITE_API_URL=https://meu-backend.replit.app
